{
  "id": "openclaw-plugin",
  "configSchema": {
    "type": "object",
    "additionalProperties": false,
    "properties": {
      "baseUrl": {
        "type": "string",
        "description": "OpenModelStudio API base URL (e.g. http://localhost:31001)"
      },
      "accessToken": {
        "type": "string",
        "description": "API key (oms_...) or JWT from OpenModelStudio. Prefer API key from Settings → API Keys so users don't provide a token."
      }
    }
  },
  "uiHints": {
    "baseUrl": {
      "label": "API base URL",
      "placeholder": "http://localhost:31001"
    },
    "accessToken": {
      "label": "Access token (API key or JWT)",
      "sensitive": true,
      "placeholder": "oms_... or eyJ..."
    }
  }
}
